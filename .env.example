# ── LLM API Keys ─────────────────────────────────────────────────────────
# At least one required. Groq is recommended (fast + free tier).
GROQ_API_KEY=
NVIDIA_API_KEY=
GEMINI_API_KEY=

# Override auto-selected model (optional)
# LLM_MODEL=groq/llama-3.3-70b-versatile

# ── Auth ─────────────────────────────────────────────────────────────────
# Generate secret: openssl rand -hex 32
SECRET_KEY=   # Required — generate with: openssl rand -hex 32
ADMIN_USERNAME=admin
# Generate hash: python -c "from passlib.context import CryptContext; print(CryptContext(['bcrypt']).hash('yourpassword'))"
ADMIN_PASSWORD_HASH=

# ── Frontend (CORS origin) ────────────────────────────────────────────────
# Set to the origin of your frontend — only this origin will be allowed.
# For dev: http://127.0.0.1:5173 | For prod: https://yourdomain.com
FRONTEND_URL=http://127.0.0.1:5173


# ── STT ──────────────────────────────────────────────────────────────────
GROQ_STT_MODEL=whisper-large-v3
# Leave blank for auto-detect language
GROQ_STT_LANGUAGE=

# ── Home Assistant ────────────────────────────────────────────────────────
HA_BASE_URL=http://192.168.1.x:8123
HA_ACCESS_TOKEN=

# ── PostgreSQL (Phase 5 — Letta) ──────────────────────────────────────────
POSTGRES_PASSWORD=rocky-secret

# ── Letta Memory Server (Phase 5) ────────────────────────────────────────
# Start Letta with: make letta  (docker compose --profile letta up)
# Leave empty to disable Letta (falls back to stateless LiteLLM)
LETTA_URL=http://rocky-letta:8283

# ── Rocky Voice Engine (TTS + effects) ───────────────────────────────────
# Start with: make voice
# VOICE_ENGINE_URL: Unified synthesis and effects service (internal Docker URL).
VOICE_ENGINE_URL=http://rocky-voice-engine:8881
BACKEND_URL=http://127.0.0.1:8000

# ── Wake Word (OpenWakeWord via voice engine) ─────────────────────────────
# Browser-facing URL for the voice engine (must be reachable from the client).
# The frontend streams mic audio to ws://<host>/ws/wakeword for wake word detection.
# All .onnx models in models/wakeword/ are loaded automatically.
# Without this, the frontend falls back to VAD-only mode (any speech triggers Rocky).
# docker-compose already sets this via VITE_VOICE_ENGINE_URL; override here for prod.
# VITE_VOICE_ENGINE_URL=http://127.0.0.1:8881

# Minimum confidence to trigger wake word (0.0–1.0, default 0.5)
# WAKEWORD_THRESHOLD=0.5

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://rocky-valkey:6381

# ── Azure Speaker Recognition (optional — free 10k/month) ─────────────────
# Create resource: portal.azure.com → Cognitive Services → Speaker Recognition
AZURE_SPEAKER_KEY=
AZURE_SPEAKER_REGION=westeurope

# ── Tools ─────────────────────────────────────────────────────────────────
TIMEZONE=Europe/Lisbon   # Used by get_datetime tool
