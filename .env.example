# -----------------------------
# LLM Config
# -----------------------------
GEMINI_API_KEY=
GEMINI_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GEMINI_MODEL="gemini-2.0-flash"

# NVIDIA NIM (Optional fallback)
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLM_MODEL="meta/llama-3.1-405b-instruct"

# Local LLM (Ollama fallback for offline operation)
LOCAL_LLM_URL="http://127.0.0.1:11434/v1"
LOCAL_LLM_MODEL="rocky"

# -----------------------------
# STT (Speech-to-Text) - Local Whisper (Priority) + Groq (Fallback)
# -----------------------------
# Local Whisper via Wyoming protocol (e.g. wyoming-faster-whisper)
# Set LOCAL_WHISPER_ENABLED=true to activate; system falls back to Groq on failure.
LOCAL_WHISPER_ENABLED=false
LOCAL_WHISPER_HOST="127.0.0.1"
LOCAL_WHISPER_PORT=10300
LOCAL_WHISPER_TIMEOUT_MS=20000

# Groq Whisper (fallback or primary when LOCAL_WHISPER_ENABLED=false)
GROQ_API_KEY=
GROQ_STT_MODEL="whisper-large-v3"
# Leave blank for auto-detect (multilingual). Set to "pt" for Portuguese, "en" for English.
GROQ_STT_LANGUAGE=

# -----------------------------
# TTS (Text-to-Speech) - KOKORO (Local)
# -----------------------------
KOKORO_URL="http://127.0.0.1:8880"
KOKORO_VOICE="af_heart"

# -----------------------------
# Home Assistant Config
# -----------------------------
HA_BASE_URL="http://192.168.1.106:8123"
HA_ACCESS_TOKEN=
# Default media_player entity for MediaControlSkill (e.g. media_player.living_room)
HA_MEDIA_PLAYER=

# -----------------------------
# Weather & Skills
# -----------------------------
VITE_OPENWEATHER_API_KEY=
